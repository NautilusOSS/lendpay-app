<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap template. The SITE_URL and SITE_VERSION placeholders are replaced
  at build/dev-serve time by the lendpay-site-version Vite plugin so the
  emitted /sitemap.xml always reflects the current canonical origin and
  deploy token. Add new <url> entries as routes ship.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>__SITE_URL__/</loc>
    <lastmod>__SITE_VERSION__</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
</urlset>
